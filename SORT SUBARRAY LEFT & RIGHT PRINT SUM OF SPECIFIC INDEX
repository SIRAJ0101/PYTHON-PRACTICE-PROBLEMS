A=[11,12,13,8,5,100,4,6,8,2,3,99,88,33]
mid=len(A)//2
left_sub=A[:mid]  
right_sub=A[mid:]   
left_sorted=sorted(left_sub)
right_sorted=sorted(right_sub,reverse=True)
final_array=left_sorted+right_sorted
print("Processed Array:",final_array)
indices=[0,6,7,13]
total_sum=sum(final_array[i] for i in indices)
print("Sum:",total_sum)
